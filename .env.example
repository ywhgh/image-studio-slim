# Image Studio Slim — runtime configuration
# Copy to .env (or set in your hosting platform) and edit as needed.

# Bind address inside the container. Leave 0.0.0.0 unless you front the
# container with another process inside the same network namespace.
HOST=0.0.0.0
PORT=8090

# Outbound timeouts. Increase if your upstream is slow.
UPSTREAM_TIMEOUT=240s
DOWNLOAD_TIMEOUT=60s

# Background image generation queue. Up to 3 jobs run at the same time; extra
# requests wait in memory until a worker is free.
IMAGE_JOB_CONCURRENCY=3
IMAGE_JOB_QUEUE_SIZE=100
IMAGE_JOB_RETENTION=2h

# Set to "true" only when your OpenAI-compatible upstream lives on the same
# private LAN as the server (e.g. an internal LiteLLM gateway). Default
# rejects loopback / RFC1918 / link-local hosts to block SSRF.
ALLOW_PRIVATE_UPSTREAM=false

# Container timezone — affects log timestamps only.
TZ=Asia/Shanghai
