# Build artifacts
frontend/dist/
frontend/node_modules/
frontend/coverage/
frontend/*.tsbuildinfo
server/web/*
!server/web/.gitkeep
!server/web/index.html

# Embedded placeholder is required for `go:embed` to compile
# but the generated frontend bundle copied here on Docker build is not.

# Go
*.exe
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Env / secrets
.env
.env.*
!.env.example

# IDE
.idea/
.vscode/
.claude/
.serena/
.codex/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Misc
tmp/
temp/
*.tmp
*.bak
.cache/

# Legacy backup (the old sub2api monolith — too big, not needed for slim deploy)
_legacy/

# Local override (compose has its own override convention)
docker-compose.override.yml
